--- !u!1001 &1247515971
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 748992540}
    m_Modifications:
    - target: {fileID: 61703609377707976, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: m_Size.x
      value: 241
      objectReference: {fileID: 0}
    - target: {fileID: 61703609377707976, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: m_Size.y
      value: 467
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: interactiveClip
      value: 
      objectReference: {fileID: 8300000, guid: de1f10421efa7be45bd602e42f5cd6cd, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: interactiveText
      value: THIS IS COMPLETELY OFFENSIVE.
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: observationClip
      value: 
      objectReference: {fileID: 8300000, guid: 4665eae525476f24a92b62da8e5ca410, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: observationText
      value: MAYBE THIS LADY CAN HELP ME SOMEHOW.
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: dialoguesText.Array.size
      value: 21
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: inventoryInteractionClip
      value: 
      objectReference: {fileID: 8300000, guid: c1cd8ad42b020794087bfdaef39b637d, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: inventoryInteractionText
      value: WOMEN ARE NOT ITEMS.
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: dialoguesClips.Array.size
      value: 21
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[0]'
      value: 'DETECTIVE: HELLO ALISON. I''M DETECTIVE EDWARD JONES AND I WANT TO
        MAKE YOU SOME QUESTIONS.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[1]'
      value: 'ALISON RUSSELL: I HOPE I CAN HELP YOU.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[2]'
      value: 'DETECTIVE: HOW LONG HAVE YOU BEEN WORKING TO THE CASTLE?'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[3]'
      value: 'ALISON RUSSELL: ABOUT A YEAR.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[4]'
      value: 'DETECTIVE: AND WHAT''S YOUR JOB THERE?'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[5]'
      value: 'ALISON RUSSELL: I''M ONE OF THE TOUR GUIDES.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[6]'
      value: 'DETECTIVE: HAD YOU SEEN EVER AGAIN THE PERPERATORS?'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[7]'
      value: 'ALISON RUSSELL: THEY HAVE VISITED THE CASTLE TWO TIMES BEOFRE THE HEIST.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[8]'
      value: 'DETECTIVE: DO YOU REMEMBER WHEN?'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[9]'
      value: 'ALISON RUSSELL: THE FIRST VISIT WAS BEFORE THREE MONTHS AND THE SECOND
        BEFORE ONE MONTH.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[0]'
      value: 
      objectReference: {fileID: 8300000, guid: 63cc4b24dcc52cb4f9731e5f14eaa97c, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[1]'
      value: 
      objectReference: {fileID: 8300000, guid: 588329cdafaac4e4db9773cea97f8180, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[2]'
      value: 
      objectReference: {fileID: 8300000, guid: 89be12f7c2737554c92e384efacff3bf, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[3]'
      value: 
      objectReference: {fileID: 8300000, guid: 968d55300e3ae8f49b7d1d8e5b657e08, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[4]'
      value: 
      objectReference: {fileID: 8300000, guid: f3ba4e430a9a3b04ebf005f0f5d84c10, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[5]'
      value: 
      objectReference: {fileID: 8300000, guid: 8ad53d5ec1649304fb6dd964d6946adf, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[6]'
      value: 
      objectReference: {fileID: 8300000, guid: 90fd45313ffde29479d84269cfce08ac, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[7]'
      value: 
      objectReference: {fileID: 8300000, guid: e6198bd401c84754293f417fdb5ce8e7, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[8]'
      value: 
      objectReference: {fileID: 8300000, guid: 3d002420e3de93d40b99660a75132b28, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[9]'
      value: 
      objectReference: {fileID: 8300000, guid: 3905af642657c114b89d8a0678065f9b, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[10]'
      value: 'DETECTIVE: HAD THEY DONE ANYTHING STRANGE?'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[11]'
      value: 'ALISON RUSSELL: I CAN''T TELL SOMETHING LIKE THIS.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[12]'
      value: 'ALISON RUSSELL: BUT THEY WERE INTRESTED FOR SOME ROOMS.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[13]'
      value: 'DETECTIVE: AND I CAN IMAGINE THAT ONE OF THEM WAS THE ROOM WITH THE
        PAINTING.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[14]'
      value: 'ALISON RUSSELL: EXACTLY.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[15]'
      value: 'DETECTIVE: I WANT YOU NOW TO TELL ME WHAT HAPPENED TODAY.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[16]'
      value: 'ALISON RUSSELL: THEY CAME EARLY IN THE MORNING AND I HAD STARTED THE
        TOUR.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[17]'
      value: 'ALISON RUSSELL: SUDDENLY, WHEN WE REACHED TO THE ROOM WITH THE PAINTING,
        THEY HIT ME FROM THE BACK AND THEY TIED ME.'
      objectReference: {fileID: 0}
