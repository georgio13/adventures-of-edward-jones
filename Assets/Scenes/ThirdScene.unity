    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: inventoryInteractionClip
      value: 
      objectReference: {fileID: 8300000, guid: 81843527cc2006d42bc6b824d9bfa41b, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: inventoryInteractionText
      value: ARE YOU CRAZY?
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: dialoguesClips.Array.size
      value: 18
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[0]'
      value: 'DETECTIVE: HELLO MY LADY. I''M DETECTIVE EDWARD JONES. CAN I ASK YOU
        SOME QUESTIONS?'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[1]'
      value: 'VISITOR: OF COURSE DETECTIVE.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[2]'
      value: 'DETECTIVE: FIRSTLY, WHAT''S YOUR NAME AND WHY YOU CAME TO THE CASTLE?'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[3]'
      value: 'OLIVE REED: MY NAME IS OLIVE REED. I TRAVELED TO SCOTLAND WITH MY HUSBAND
        FOR VACATIONS AND WE CAME TO DRUMLANRIG TO SEE THE EXHIBITS OF THE CASTLE.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[4]'
      value: 'DETECTIVE: WERE YOU HERE DURING THE HEIST?'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[5]'
      value: 'OLIVE REED: YES DETECTIVE. WE SAW THEM.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[6]'
      value: 'DETECTIVE: I WANT TO TELL ME WITH DETAILS WHAT DID YOU SEE.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[7]'
      value: 'OLIVE REED: WE HEARD THE ALARM GOING OFF AND THE FIRST MAN CLIMBED
        OVER THE WALL.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[8]'
      value: 'OLIVE REED: HE SAID ''DON''T WORRY LOVE. WE''RE THE POLICE. THIS IS
        JUST A PRACTICE.'''
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[9]'
      value: 'OLIVE REED: WHEN THE SECOND MAN CAME OVER THE WALL WE FELT SOMETHING
        WAS GOING ON.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[0]'
      value: 
      objectReference: {fileID: 8300000, guid: 25efd598e756b8247bf20624380ff596, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[1]'
      value: 
      objectReference: {fileID: 8300000, guid: 49808eb42026a8f4d9f93942e1e987c3, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[2]'
      value: 
      objectReference: {fileID: 8300000, guid: caeda8653add8584e9862abdc36fe1cf, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[3]'
      value: 
      objectReference: {fileID: 8300000, guid: 6ff13efe8ee7d8d43aaa61e692612701, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[4]'
      value: 
      objectReference: {fileID: 8300000, guid: dda4eaec267a89946bbb843ee7874741, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[5]'
      value: 
      objectReference: {fileID: 8300000, guid: c7abf479ee2f66645b149f43614bcb3d, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[6]'
      value: 
      objectReference: {fileID: 8300000, guid: 186f6875cabf07348a7d2ad75b8e47ec, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[7]'
      value: 
      objectReference: {fileID: 8300000, guid: 17d1e60dc80815846a749f25a7401664, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[8]'
      value: 
      objectReference: {fileID: 8300000, guid: badb7d3b50effb14cab884e38e155316, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[9]'
      value: 
      objectReference: {fileID: 8300000, guid: bfdf8d90d86d5224380ab71acbbc01af, type: 3}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[10]'
      value: 'OLIVE REED: THE THIRD MAN OVER THE WALL WAS CARRYING SOMETHING UNDER
        HIS ARM WHICH APPEARED TO BE THE SAME SIZE AS WHAT WE''VE BEEN TOLD ABOUT
        THE PAINTING.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[11]'
      value: 'OLIVE REED: IT ALL HAPPENED VERY QUICKLY AND THEY HAD TO RUN PAST US
        TO GET INTO THEIR CAR.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[12]'
      value: 'OLIVE REED: I MUST SAY WE WERE NOT THREATENED IN ANY WAY BUT WE WERE
        VERY SUPRISED BY THE WHOLE THING.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[13]'
      value: 'DETECTIVE: I THINK THAT ALL THESE ARE VERY USEFUL.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[14]'
      value: 'DETECTIVE: YOU MUST DESCRIBE THEM TO MY COLLEAGUE, SO HE CAN MAKE THEIR
        PORTRAITS.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[15]'
      value: 'OLIVE REED: OF COURSE DETECTIVE.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[16]'
      value: 'DETECTIVE: THANK YOU VERY MUCH FOR YOUR HELP. GOODBYE.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesText.Array.data[17]'
      value: 'OLIVE REED: GOODBYE DETECTIVE.'
      objectReference: {fileID: 0}
    - target: {fileID: 114042727509347652, guid: 6df48c06c91791f4995ebf16a26984f1, type: 3}
      propertyPath: 'dialoguesClips.Array.data[10]'
